{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"git": {
		"deploymentEnabled": {
			"main": true,
			"**": false
		}
	},
	"functions": {
		"app/api/mcp/route.ts": {
			"memory": 512,
			"maxDuration": 15
		},
		"app/api/op/[...path]/route.ts": {
			"memory": 256,
			"maxDuration": 10
		},
		"app/api/stats/route.ts": {
			"memory": 256,
			"maxDuration": 15
		},
		"app/api/search/route.ts": {
			"memory": 512,
			"maxDuration": 15
		},
		"app/api/newsletter/route.ts": {
			"memory": 256,
			"maxDuration": 10
		},
		"app/[...slug]/page.tsx": {
			"memory": 3008,
			"maxDuration": 60
		},
		"app/blog/[slug]/page.tsx": {
			"memory": 3008,
			"maxDuration": 60
		},
		"app/blog/page.tsx": {
			"memory": 1024,
			"maxDuration": 30
		},
		"app/pages/[pageName]/page.tsx": {
			"memory": 1769,
			"maxDuration": 30
		}
	},
	"rewrites": [
		{
			"source": "/:path*",
			"has": [
				{
					"type": "host",
					"value": "mcp.uxpatterns.dev"
				}
			],
			"destination": "/api/mcp"
		}
	],
	"headers": [
		{
			"source": "/:path*",
			"has": [
				{
					"type": "host",
					"value": "mcp.uxpatterns.dev"
				}
			],
			"headers": [
				{
					"key": "Access-Control-Allow-Origin",
					"value": "*"
				},
				{
					"key": "Access-Control-Allow-Methods",
					"value": "GET, POST, OPTIONS"
				},
				{
					"key": "Access-Control-Allow-Headers",
					"value": "Accept, Content-Type, MCP-Protocol-Version, MCP-Session-Id"
				},
				{
					"key": "Access-Control-Expose-Headers",
					"value": "MCP-Session-Id"
				}
			]
		}
	]
}
