{
	"name": "web",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"analyze": "export ANALYZE=true && next build",
		"prebuild": "velite build && node scripts/validate-mermaid.mjs && node scripts/generate-pattern-dates.mjs",
		"build": "next build",
		"check": "node scripts/validate-mermaid.mjs && node scripts/validate-pattern-structure.mjs && node scripts/validate-pattern-resources.mjs && tsc --noEmit",
		"dev": "portless uxpatterns next dev --turbo -p 3060",
		"dev:velite": "velite --watch",
		"sync:pattern-resources": "node scripts/sync-pattern-resources.mjs",
		"skills:generate": "node scripts/generate-pattern-skills.mjs",
		"glossary:audit": "node scripts/sync-glossary-terms.mjs --mode=audit",
		"glossary:relevance": "node scripts/sync-glossary-terms.mjs --mode=relevance",
		"glossary:sync": "node scripts/sync-glossary-terms.mjs --mode=sync",
		"start": "next start",
		"test": "vitest run",
		"test:glossary-sync": "node --test scripts/glossary-sync-lib.test.mjs",
		"test:mermaid": "node --test scripts/validate-mermaid.test.mjs",
		"test:watch": "vitest",
		"test:pattern-structure": "node --test scripts/validate-pattern-structure.test.mjs",
		"test:pattern-resources": "node --test scripts/validate-pattern-resources.test.mjs",
		"test:skills": "node --test scripts/pattern-skills-lib.test.mjs",
		"audit:pattern-resources": "node scripts/audit-pattern-resources.mjs",
		"velite:build": "velite build",
		"postinstall": "fumadocs-mdx",
		"art": "tsx scripts/ux-covers/generator.ts",
		"art:generate-ai": "tsx scripts/ux-covers/generator.ts",
		"art:optimize-ai": "tsx scripts/ux-covers/optimizer.ts",
		"art:render": "tsx scripts/render-pattern-art.tsx",
		"art:scan-ai": "tsx scripts/ux-covers/generator.ts --scan-only"
	},
	"dependencies": {
		"@codesandbox/sandpack-react": "^2.20.0",
		"@next/bundle-analyzer": "^16.1.1",
		"@radix-ui/react-accordion": "^1.2.12",
		"@radix-ui/react-aspect-ratio": "^1.1.8",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-navigation-menu": "^1.2.14",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-presence": "^1.1.5",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-slot": "^1.2.4",
		"@sentry/nextjs": "^10.32.1",
		"@shikijs/engine-javascript": "^3.21.0",
		"@shikijs/engine-oniguruma": "^3.21.0",
		"@ux-patterns/analytics": "workspace:*",
		"@ux-patterns/constants": "workspace:*",
		"@ux-patterns/newsletter": "workspace:*",
		"@ux-patterns/seo": "workspace:*",
		"@ux-patterns/tracking": "workspace:*",
		"@ux-patterns/ui": "workspace:*",
		"@xyflow/react": "^12.10.0",
		"botid": "^1.5.10",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dagre": "^0.8.5",
		"date-fns": "^4.1.0",
		"feed": "^5.1.0",
		"fumadocs-core": "16.4.6",
		"fumadocs-mdx": "14.2.4",
		"fumadocs-typescript": "^5.0.1",
		"fumadocs-ui": "16.4.6",
		"gray-matter": "^4.0.3",
		"html-to-image": "^1.11.13",
		"import-in-the-middle": "^2.0.1",
		"lucide-react": "^0.562.0",
		"markdown-to-jsx": "^9.5.1",
		"mermaid": "^11.12.2",
		"motion": "^12.25.0",
		"next": "16.1.7",
		"next-mdx-remote": "^6.0.0",
		"next-themes": "^0.4.6",
		"octokit": "^5.0.5",
		"qrcode": "^1.5.4",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"react-markdown": "^10.1.0",
		"react-resizable-panels": "^4.3.3",
		"remark": "^15.0.1",
		"remark-gfm": "^4.0.1",
		"remark-mdx": "^3.1.1",
		"remove-markdown": "^0.6.2",
		"require-in-the-middle": "^8.0.1",
		"shiki": "^3.21.0",
		"tailwind-merge": "^3.4.0",
		"tailwindcss-animate": "^1.0.7",
		"ts-morph": "^27.0.2",
		"unified": "^11.0.5",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@orama/orama": "^3.1.18",
		"@shikijs/rehype": "^3.21.0",
		"@tailwindcss/postcss": "^4.1.18",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.1",
		"@types/dagre": "^0.7.53",
		"@types/mdx": "^2.0.13",
		"@types/node": "25.0.5",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"fast-glob": "^3.3.3",
		"jsdom": "^27.4.0",
		"postcss": "^8.5.6",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-slug": "^6.0.0",
		"remark-retext": "^6.0.1",
		"retext": "^9.0.0",
		"retext-english": "^5.0.0",
		"retext-keywords": "^8.0.2",
		"retext-pos": "^5.0.0",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"velite": "^0.3.1",
		"vitest": "^4.0.16"
	}
}
