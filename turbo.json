{
	"$schema": "https://turbo.build/schema.json",
	"globalDependencies": ["**/.env.*local"],
	"remoteCache": {
		"signature": true
	},
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [
				".next/**",
				"!.next/cache/**",
				"out/**",
				"registry.json",
				"public/r/**"
			],
			"env": [
				"NODE_ENV",
				"NEXT_PUBLIC_*",
				"SENTRY_*",
				"VERCEL_*",
				"UPSTASH_REDIS_REST_URL",
				"UPSTASH_REDIS_REST_TOKEN",
				"KV_REST_API_URL",
				"KV_REST_API_TOKEN",
				"KV_REST_API_READ_ONLY_TOKEN",
				"KV_URL",
				"REDIS_URL",
				"RATE_LIMIT_STORE_TIMEOUT_MS",
				"MDX_API_KEY",
				"MAILERLITE_API_KEY",
				"MAILERLITE_GROUP_IDS",
				"RESEND_API_KEY",
				"RESEND_AUDIENCE_ID",
				"OPENPANEL_CLIENT_ID",
			"OPENPANEL_CLIENT_SECRET",
				"TURBO_REMOTE_CACHE_SIGNATURE_KEY",
				"GITHUB_TOKEN"
			]
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"lint": {
			"outputs": []
		},
		"check": {
			"outputs": []
		},
		"check:type": {
			"outputs": []
		},
		"format": {
			"outputs": []
		},
		"test": {
			"outputs": [],
			"dependsOn": []
		}
	}
}
